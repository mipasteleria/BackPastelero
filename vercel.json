{
  "builds": [
    {
      "src": "./index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "crons": [
    {
      "path": "/jobs/cleanup-imagenes",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/jobs/recordatorios-cotizacion",
      "schedule": "30 15 * * *"
    }
  ]
}
